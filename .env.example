# Copy this to .env and fill in real values before deploying
# Generate secrets with: openssl rand -base64 32

# Database
MYSQL_DATABASE=jwellkeeper
MYSQL_USER=jwellkeeper
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# Backend secrets
JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_32
JWT_EXPIRATION_MINUTES=1440
QR_SIGNING_SECRET=CHANGE_ME_run_openssl_rand_base64_32
QR_IMAGE_SIZE=300

# Frontend
SESSION_SECRET=CHANGE_ME_run_openssl_rand_base64_32
NEXT_PUBLIC_APP_NAME=JwellKeeper
BACKEND_API_URL=http://backend:8080
